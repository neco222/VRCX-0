{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "composite": false,
        "incremental": false,
        "noEmit": true
    },
    "include": [
        "src/domain/**/*.ts",
        "src/platform/**/*.ts",
        "src/repositories/**/*.ts",
        "src/services/domainIngestionService.ts",
        "src/shared/constants/**/*.ts",
        "src/state/**/*.ts",
        "src/shared/utils/**/*.ts"
    ],
    "exclude": ["node_modules", "build", "dist"]
}
